use "./grains/cli"

if (sys.isRoot()) {
  print("\x1b[33mwarn\x1b[0m Running sand as root is not recommended.")
  print("     Local installs go to ext_grains/. Use --global for system-wide installs.")
  print("")
}

try {
  cli.run(sys.args)
} catch (err) {
  print("\x1b[31merror\x1b[0m %{err}")
  sys.exit(1)
}
