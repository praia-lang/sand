use "colors"
use "./grains/cli"

if (sys.isRoot()) {
  print(colors.yellow("warn") + " Running sand as root is not recommended.")
  print("     Local installs go to ext_grains/. Use --global for system-wide installs.")
  print("")
}

try {
  cli.run(sys.args)
} catch (err) {
  print(colors.red("error") + " " + err)
  sys.exit(1)
}
