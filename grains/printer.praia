use "colors"

func success(msg) { print(colors.green("ok") + " " + msg) }
func error(msg)   { print(colors.red("error") + " " + msg) }
func warn(msg)    { print(colors.yellow("warn") + " " + msg) }
func info(msg)    { print(colors.cyan("info") + " " + msg) }
func header(msg)  { print(colors.bold(msg)) }

export { success, error, warn, info, header }
